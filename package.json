{
  "name": "oracle-terminal-canvas",
  "version": "0.1.0",
  "private": true,
  "description": "Infinite-canvas terminal workspace app for macOS Electron, web, and responsive mobile browsers.",
  "main": "./out/main/index.js",
  "scripts": {
    "start": "npm run dev",
    "dev": "electron-vite dev",
    "web": "vite --host 0.0.0.0 --config vite.web.config.ts",
    "web:terminal": "concurrently -k \"npm:terminal:server\" \"cross-env VITE_TERMINAL_WS_URL=ws://127.0.0.1:8787 vite --host 0.0.0.0 --config vite.web.config.ts\"",
    "terminal:server": "tsx server/pty-websocket.ts",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && electron-vite build",
    "build:web": "npm run typecheck && vite build --config vite.web.config.ts",
    "dist:mac": "npm run build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.8"
  },
  "build": {
    "appId": "com.oracle.terminalcanvas",
    "productName": "Oracle Terminal Canvas",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  }
}
